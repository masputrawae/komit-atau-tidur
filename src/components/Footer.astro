---
import { SITE } from '../site.config'
import { relUrl } from '../utils'

const title = SITE.title
const year = new Date().getFullYear()
---

<footer
	class="m-auto mt-10 flex w-full flex-col items-center gap-2 border-t border-t-neutral-700 text-xs md:flex-row md:justify-between"
>
	<p>
		© {year} · {title} · All rights reserved. | <a
			class="text-blue-400 hover:text-blue-200"
			href={relUrl('/disclaimer/')}>Disclaimer</a
		>
	</p>
	<p>
		Made with ❤️ using <a
			class="text-blue-400 hover:text-blue-200"
			href="https://astro.build/"
			target="_blank"
			rel="noopener noreferrer">{Astro.generator}</a
		>
	</p>
</footer>
